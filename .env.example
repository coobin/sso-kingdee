PORT=3002
APP_BASE_URL=https://kingdee.chencytech.com

# Auth mode:
# - trusted_headers: recommended for Authelia + Nginx Proxy Manager
# - exchange_code: if you already have a separate auth backend that can exchange code -> user profile
AUTH_MODE=trusted_headers
LOG_LEVEL=info
LOG_REQUESTS=true
TZ=Asia/Shanghai
LOG_UTC_OFFSET_MINUTES=480
AUTH_LOGIN_URL=
AUTH_EXCHANGE_URL=
AUTH_EXCHANGE_TOKEN=
AUTH_EXCHANGE_TIMEOUT_MS=5000

# Trusted header names
REMOTE_USER_HEADER=Remote-User
REMOTE_EMAIL_HEADER=Remote-Email
REMOTE_NAME_HEADER=Remote-Name
REMOTE_KINGDEE_USERNAME_HEADER=Remote-Kingdee-Username

# Which identity field becomes the Kingdee username.
# Options: auto / kingdee_header / remote_user / remote_name / email / email_localpart
KINGDEE_USERNAME_SOURCE=auto

# Cookie settings
KINGDEE_COOKIE_NAME=kingdee_sso_session
COOKIE_SECURE=true
COOKIE_DOMAIN=kingdee.chencytech.com
SESSION_SECRET=replace-with-a-long-random-string
SESSION_TTL_SECONDS=3600

# Kingdee Cloud
KINGDEE_BASE_URL=https://erp.example.com
KINGDEE_DBID=YOUR_DBID
KINGDEE_APP_ID=YOUR_APP_ID
KINGDEE_APP_SECRET=YOUR_APP_SECRET
KINGDEE_LCID=2052
KINGDEE_ORIGIN_TYPE=SimPas
KINGDEE_SIGN_ALGO=sha256
KINGDEE_SIGN_SORT=true
KINGDEE_UD_ENCODING=utf-8
KINGDEE_SIGN_USERNAME_MODE=raw
KINGDEE_SIGN_USERNAME_OVERRIDE=
KINGDEE_UD_USERNAME_OVERRIDE=
KINGDEE_SIGN_INCLUDE_SECOND_CHECK=false
KINGDEE_SECOND_CHECK_SECRET=
KINGDEE_SIGN_INCLUDE_ENTRY_ROLE=true
KINGDEE_SIGN_INCLUDE_PERMITCOUNT=true

# Optional target page / role
KINGDEE_ENTRY_ROLE=
KINGDEE_FORM_ID=
KINGDEE_FORM_TYPE=
KINGDEE_PKID=
KINGDEE_OPEN_MODE=
KINGDEE_OTHER_ARGS=|{'permitcount':'0'}
KINGDEE_FORM_ARGS=
KINGDEE_LOGIN_THEN=
KINGDEE_LOGIN_AGAIN=
